---
import MainLayout from "../layouts/mainlayout.astro";
---

<MainLayout title="Projets">
  <!-- Section Projet *3 -->
  <section class="max-w-7xl mx-auto px-6 pt-12">
    <a href="/projets" class="group relative block w-full">
      <div
        class="relative overflow-hidden rounded-2xl border border-orange-500 md:border-white/5 bg-zinc-900/20 p-8 md:p-16 transition-all duration-500 group-hover:border-orange-500/30 group-hover:bg-zinc-900/40"
      >
        <div
          class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-orange-500/5 blur-[100px] transition-opacity opacity-0 group-hover:opacity-100"
        >
        </div>

        <div
          class="relative flex flex-col md:flex-row md:items-end justify-between gap-8"
        >
          <div class="max-w-2xl flex flex-col gap-4">
            <div class="mb-2 flex items-center gap-2">
              <span class="h-px w-8 bg-orange-500"></span>
              <span
                class="text-xs font-black uppercase tracking-[0.3em] text-orange-500"
                >Projet en cours</span
              >
            </div>
            <h2
              class="text-2xl md:text-4xl font-bold tracking-tighter text-white mb-3"
            >
              Architecture RAG <br />multi<span
                class="text-zinc-500 group-hover:text-white transition-colors"
                >-agents</span
              >
            </h2>
            <h3
              class="text-sm md:text-xl font-bold tracking-tighter text-white mb-1"
            >
              Périmètre d'Analyse — AERONAUTIQUE
            </h3>
            <p class="text-zinc-500 text-xs md:text-lg leading-relaxed">
              Ce projet explore les mécaniques de vectorisation et d'indexation
              de données hétérogènes pour en optimiser l'exploitation
              opérationnelle. L'enjeu est de tester différents outils de
              traitement sémantique afin de transformer des flux bruts en
              ressources exploitables, préfigurant ainsi un usage concret en
              milieu professionnel.
            </p>
            <div class="pt-4 border-t border-white/10 block w-full clear-both">
              <div
                class="text-xs md:text-sm font-black uppercase tracking-[0.4em] text-zinc-500 mb-4"
              >
                Stack Technique
              </div>
              <div
                class="text-xs md:text-sm text-orange-500 uppercase tracking-normal"
              >
                Docker &bull; n8n &bull; anything LLM &bull; LanceDB &bull;
                ollama
              </div>
            </div>
          </div>

          <div
            class="flex h-16 w-16 items-center justify-center rounded-full border border-orange-500 md:border-white/10 bg-black transition-all duration-500 group-hover:border-orange-500 group-hover:translate-x-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 text-white group-hover:text-orange-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </div>
        </div>

        <div
          class="absolute bottom-0 left-0 h-1 w-0 bg-orange-500 transition-all duration-700 group-hover:w-full"
        >
        </div>
      </div>
    </a>
  </section>

  <!-- Section Projet *2 -->
  <section class="max-w-7xl mx-auto px-6 pt-12">
    <a href="/prisme-energie" class="group relative block w-full">
      <div
        class="relative overflow-hidden rounded-2xl border border-orange-500 md:border-white/5 bg-zinc-900/20 p-8 md:p-16 transition-all duration-500 group-hover:border-orange-500/30 group-hover:bg-zinc-900/40"
      >
        <div
          class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-orange-500/5 blur-[100px] transition-opacity opacity-0 group-hover:opacity-100"
        >
        </div>

        <div
          class="relative flex flex-col md:flex-row md:items-end justify-between gap-8"
        >
          <div class="max-w-2xl flex flex-col gap-4">
            <div class="mb-2 flex items-center gap-2">
              <span class="h-px w-8 bg-orange-500"></span>
              <span
                class="text-xs font-black uppercase tracking-[0.3em] text-orange-500"
                >Accéder au projet</span
              >
            </div>
            <h2
              class="text-2xl md:text-4xl font-bold tracking-tighter text-white mb-3"
            >
              Architecture d'extraction<br />et d'Analyse <span
                class="text-zinc-500 group-hover:text-white transition-colors"
                >des Flux</span
              >
            </h2>
            <h3
              class="text-sm md:text-xl font-bold tracking-tighter text-white mb-1"
            >
              Périmètre d'Analyse — ÉNERGIE
            </h3>
            <p class="text-zinc-500 text-xs md:text-lg leading-relaxed">
              Ce projet est un démonstrateur technique explorant
              l'automatisation de la collecte de données géopolitiques sous le
              prisme de l'énergie. L'objectif est de tester une architecture
              capable de croiser des flux d'informations spécialisés pour en
              extraire des synthèses préliminaires. C'est un travail de
              structure et de méthode, visant à illustrer le potentiel de
              l'agrégation de données sur des secteurs stratégiques comme l'Oil
              & Gas et l'Électricité.
            </p>
            <div class="pt-4 border-t border-white/10 block w-full clear-both">
              <div
                class="text-xs md:text-sm font-black uppercase tracking-[0.4em] text-zinc-500 mb-4"
              >
                Stack Technique
              </div>
              <div
                class="text-xs md:text-sm text-orange-500 uppercase tracking-normal"
              >
                n8n &bull; Strapi &bull; Docker &bull; Ollama &bull; Gemini API
              </div>
            </div>
          </div>

          <div
            class="flex h-16 w-16 items-center justify-center rounded-full border border-orange-500 md:border-white/10 bg-black transition-all duration-500 group-hover:border-orange-500 group-hover:translate-x-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 text-white group-hover:text-orange-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </div>
        </div>

        <div
          class="absolute bottom-0 left-0 h-1 w-0 bg-orange-500 transition-all duration-700 group-hover:w-full"
        >
        </div>
      </div>
    </a>
  </section>

  <!-- Section Projet *1 -->
  <section class="max-w-7xl mx-auto px-6 pt-12">
    <a href="/prisme-metallurgy" class="group relative block w-full">
      <div
        class="relative overflow-hidden rounded-2xl border border-orange-500 md:border-white/5 bg-zinc-900/20 p-8 md:p-16 transition-all duration-500 group-hover:border-orange-500/30 group-hover:bg-zinc-900/40"
      >
        <div
          class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-orange-500/5 blur-[100px] transition-opacity opacity-0 group-hover:opacity-100"
        >
        </div>

        <div
          class="relative flex flex-col md:flex-row md:items-end justify-between gap-8"
        >
          <div class="max-w-2xl flex flex-col gap-4">
            <div class="mb-2 flex items-center gap-2">
              <span class="h-px w-8 bg-orange-500"></span>
              <span
                class="text-xs font-black uppercase tracking-[0.3em] text-orange-500"
                >Accéder au projet</span
              >
            </div>
            <h2
              class="text-2xl md:text-4xl font-bold tracking-tighter text-white mb-3"
            >
              Micro-service IA d'Extraction<br /> et de Structuration <span
                class="text-zinc-500 group-hover:text-white transition-colors"
                >de Données</span
              >
            </h2>
            <h3
              class="text-sm md:text-xl font-bold tracking-tighter text-white mb-1"
            >
              Périmètre d'Analyse — METALLURGIE
            </h3>
            <p class="text-zinc-500 text-xs md:text-lg leading-relaxed">
              Ce projet explore Node-RED comme moteur de microservices pour
              orchestrer l'extraction et la structuration de données web via
              l'IA (Gemini API).<br />Je présente ici une extraction ciblée sur
              les innovations en science des matériaux et métallurgie, optimisée
              pour identifier les opportunités stratégiques du secteur
              aéronautique.
            </p>
            <div class="pt-4 border-t border-white/10 block w-full clear-both">
              <div
                class="text-xs md:text-sm font-black uppercase tracking-[0.4em] text-zinc-500 mb-4"
              >
                Stack Technique
              </div>
              <div
                class="text-xs md:text-sm text-orange-500 uppercase tracking-normal"
              >
                Docker &bull; Node-Red &bull; Gemini API
              </div>
            </div>
          </div>

          <div
            class="flex h-16 w-16 items-center justify-center rounded-full border border-orange-500 md:border-white/10 bg-black transition-all duration-500 group-hover:border-orange-500 group-hover:translate-x-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 text-white group-hover:text-orange-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </div>
        </div>

        <div
          class="absolute bottom-0 left-0 h-1 w-0 bg-orange-500 transition-all duration-700 group-hover:w-full"
        >
        </div>
      </div>
    </a>
  </section>
</MainLayout>
