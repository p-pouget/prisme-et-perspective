<script>
  // ==============================
  // SPECIAL LONG DOC MD != DES AUTRES
  // ==============================
  function initAccordion() {
    const triggers = document.querySelectorAll(".accordion-trigger");

    triggers.forEach((trigger) => {
      trigger.replaceWith(trigger.cloneNode(true));
    });

    const newTriggers = document.querySelectorAll(".accordion-trigger");

    newTriggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const content = trigger.nextElementSibling as HTMLElement | null;
        const arrow = trigger.querySelector(".arrow") as HTMLElement | null;

        if (!content || !arrow) return;

        const isOpen = content.classList.contains("is-open");

        if (isOpen) {
          content.style.maxHeight = content.scrollHeight + "px";

          void content.offsetHeight;

          content.style.maxHeight = ""; // "" est préféré à null en TypeScript
          content.classList.remove("is-open");
          arrow.style.transform = "rotate(0deg)";
        } else {
          content.style.maxHeight = content.scrollHeight + "px";
          content.classList.add("is-open");
          arrow.style.transform = "rotate(180deg)";

          setTimeout(() => {
            if (content.classList.contains("is-open")) {
              content.style.maxHeight = "none";
            }
          }, 700);
        }
      });
    });
  }

  initAccordion();
  document.addEventListener("astro:after-swap", initAccordion);
</script>
