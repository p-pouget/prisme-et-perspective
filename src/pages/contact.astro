---
import MainLayout from "../layouts/mainlayout.astro";
---

<MainLayout title="Projets">
  <section class="max-w-7xl mx-auto px-6 py-32">
    <div class="max-w-3xl mt-8 mb-20">
      <h1
        class="text-white text-5xl md:text-7xl font-bold tracking-tighter mb-6"
      >
        Contact<span class="text-orange-500">.</span>
      </h1>
      <p class="text-zinc-400 text-lg md:text-xl leading-relaxed">
        Pour toute question relative aux méthodologies employées ou pour
        discuter de l'évolution des outils d'automatisation, vous pouvez me
        joindre via mon profil professionnel.
      </p>
    </div>

    <a
      href="https://www.linkedin.com/in/pierre-pouget-53b3743bb/"
      target="_blank"
      class="group relative block w-full mt-12"
    >
      <div
        class="relative overflow-hidden rounded-2xl border border-white/5 bg-zinc-900/10 p-8 md:p-16 transition-all duration-500 group-hover:border-orange-500/20 group-hover:bg-zinc-900/30"
      >
        <div
          class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-orange-500/[0.02] blur-[100px] transition-opacity opacity-0 group-hover:opacity-100"
        >
        </div>

        <div
          class="relative flex flex-col md:flex-row md:items-center justify-between gap-12"
        >
          <div class="max-w-2xl flex flex-col gap-8">
            <div class="flex items-center gap-6">
              <div
                class="h-16 w-16 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-zinc-400 text-2xl font-black group-hover:text-orange-500 group-hover:border-orange-500/30 transition-all"
              >
                PP
              </div>
              <div>
                <div class="flex items-center gap-2 mb-4">
                  <span class="h-px w-6 bg-zinc-700"></span>
                  <span
                    class="text-xs font-black uppercase tracking-[0.4em] text-zinc-400"
                    >Consultation Profil</span
                  >
                </div>
                <h2
                  class="text-3xl md:text-5xl font-bold tracking-tighter text-white"
                >
                  Pierre <span
                    class="text-zinc-500 group-hover:text-white transition-colors"
                    >Pouget</span
                  >
                </h2>
              </div>
            </div>

            <div class="space-y-4">
              <h3
                class="text-lg md:text-2xl font-bold tracking-tighter text-zinc-300 uppercase"
              >
                Architecture de Données & Automatisation
              </h3>
              <p
                class="text-zinc-500 text-lg md:text-lg leading-relaxed max-w-xl"
              >
                Ce blog documente mes recherches personnelles sur l'intégration
                de l'intelligence artificielle locale et l'optimisation des flux
                décisionnels. Une démarche axée sur la rigueur technique et
                l'efficience opérationnelle.
              </p>
            </div>

            <div class="pt-8 border-t border-white/5 flex items-center gap-6">
              <div
                class="text-xs font-black uppercase tracking-[0.3em] text-orange-500/80"
              >
                Réseau Professionnel
              </div>
              <div class="h-px flex-1 bg-white/5"></div>
            </div>
          </div>

          <div class="flex flex-col items-center gap-6">
            <div
              class="flex h-20 w-20 items-center justify-center rounded-2xl border border-white/5 bg-white/5 transition-all duration-500 group-hover:border-orange-500/40 group-hover:bg-orange-500/5 group-hover:-translate-y-2"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8 text-zinc-500 group-hover:text-orange-500 transition-colors"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                ></path>
              </svg>
            </div>
            <span
              class="text-sm font-black uppercase tracking-[0.5em] text-zinc-600 group-hover:text-zinc-400 transition-colors"
              >LinkedIn</span
            >
          </div>
        </div>

        <div
          class="absolute bottom-0 left-0 h-[2px] w-0 bg-orange-500/40 transition-all duration-1000 group-hover:w-full"
        >
        </div>
      </div>
    </a>
  </section>
</MainLayout>
